# Renomeie este arquivo para .env e preencha com seus dados

# Banco de dados MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_NAME=checklist

# JWT — troque por uma string longa e aleatória
JWT_SECRET=checklist_super_secret_jwt_key_troque_isso

# Porta do servidor
PORT=3001

# HTTPS (opcional)
# HTTPS_PORT=3443
# SSL_KEY_PATH=./certs/key.pem
# SSL_CERT_PATH=./certs/cert.pem
